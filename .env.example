# 1Claw — HSM vault + Intents API  (docs.1claw.xyz)
ONECLAW_API_URL=https://api.1claw.xyz
ONECLAW_API_KEY=
# Intents are agent-scoped: POST /v1/agents/:id/transactions
ONECLAW_AGENT_ID=

# Shroud — OpenAI-compatible TEE LLM proxy  (docs.1claw.xyz)
# Auth is via the X-Shroud-Agent-Key header (not Authorization: Bearer).
SHROUD_API_URL=https://shroud.1claw.xyz/v1
SHROUD_API_KEY=
SHROUD_MODEL=claude-sonnet-4-5
# Optional; auto-derived from the model name (claude-* -> anthropic) when blank.
SHROUD_PROVIDER=

# GitLawb — decentralized git (gl CLI + node)  (github.com/Gitlawb/node)
# Identity is Ed25519/did:key; auth is HTTP Signatures, so there's no token.
GITLAWB_NODE_URL=http://localhost:7545

# Bankr — token launch + fee swaps  (docs.bankr.bot)
BANKR_API_URL=https://api.bankr.bot
# bk_... key with tokenLaunchApiEnabled
BANKR_API_KEY=

# Farcaster fallback (optional alternative to the Bankr API)
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
FARCASTER_FID=

# Base
BASE_RPC_URL=https://mainnet.base.org
