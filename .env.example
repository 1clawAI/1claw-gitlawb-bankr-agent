# =============================================================================
# To run the agent you normally only need ONECLAW_HUMAN_API_KEY below, then:
#   pnpm bootstrap   # provisions the agent + vault, prompts for other secrets,
#                    # and writes ONECLAW_AGENT_* back into your .env
#   pnpm agent       # runs with the agent key; pulls every other secret from 1Claw
# =============================================================================

# 1Claw — get a HUMAN key from https://docs.1claw.xyz  (bootstrap uses this)
ONECLAW_API_URL=https://api.1claw.xyz
ONECLAW_HUMAN_API_KEY=

# Written by `pnpm bootstrap` — the agent's own scoped credentials (runtime).
ONECLAW_AGENT_ID=
ONECLAW_AGENT_API_KEY=

# --- Everything below is optional: bootstrap stores these in the 1Claw vault. ---

# Shroud — OpenAI-compatible TEE LLM proxy (defaults to using the agent key)
SHROUD_API_URL=https://shroud.1claw.xyz/v1
SHROUD_API_KEY=
SHROUD_MODEL=claude-sonnet-4-5
SHROUD_PROVIDER=

# GitLawb — decentralized git (gl CLI + node; identity-based, no token)
GITLAWB_NODE_URL=http://localhost:7545

# Bankr — token launch (stored in vault by bootstrap)
BANKR_API_URL=https://api.bankr.bot
BANKR_API_KEY=

# Farcaster fallback (stored in vault by bootstrap)
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
FARCASTER_FID=

# Base
BASE_RPC_URL=https://mainnet.base.org
