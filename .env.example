# =============================================================================
# Bootstrap accepts keys from .env OR masked interactive prompts (shown as *).
#   pnpm bootstrap   # provisions agent + vault; Bankr key stored in 1Claw vault
#   pnpm agent       # runs with the agent key; pulls Bankr from the vault
# =============================================================================

# 1Claw human key — bootstrap only (1ck_… from https://docs.1claw.xyz)
# Leave blank to enter interactively; never logged to the console.
ONECLAW_API_URL=https://api.1claw.xyz
ONECLAW_HUMAN_API_KEY=

# Bootstrap profile — set before `pnpm bootstrap` or answer prompts (written back to .env).
ONECLAW_AGENT_NAME=reference-agent
ONECLAW_VAULT_NAME=reference-agent-secrets
BANKR_TOKEN_SYMBOL=AGENT
# Optional; leave blank to use "Agent <id>" at deploy time.
BANKR_TOKEN_NAME=
# Optional logo — direct https URL (PNG/JPG/WebP/GIF); Bankr field: `image`
BANKR_TOKEN_IMAGE=

# Written by `pnpm bootstrap` — the agent's own scoped credentials (runtime).
ONECLAW_AGENT_ID=
ONECLAW_AGENT_API_KEY=
ONECLAW_VAULT_ID=

# --- Bootstrap-only: pass into vault, then cleared from .env after bootstrap. ---
# Leave blank to enter interactively (masked with *). Runtime pulls from vault.

# Shroud — OpenAI-compatible TEE LLM proxy (defaults to using the agent key)
SHROUD_API_URL=https://shroud.1claw.xyz/v1
SHROUD_API_KEY=
SHROUD_MODEL=gpt-4o-mini
SHROUD_PROVIDER=

# GitLawb — decentralized git (gl CLI + node; identity-based, no token)
GITLAWB_NODE_URL=https://node.gitlawb.com

# Bankr — bootstrap input only; stored in vault, then cleared from .env
BANKR_API_URL=https://api.bankr.bot
BANKR_API_KEY=

# Farcaster — optional bootstrap input; stored in vault if provided
NEYNAR_API_KEY=
NEYNAR_SIGNER_UUID=
FARCASTER_FID=

# Base
BASE_RPC_URL=https://mainnet.base.org
